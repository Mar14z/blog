# 服务器配置
PORT=3000
HOST=0.0.0.0

# MongoDB 配置
MONGODB_URI=mongodb://localhost:27017/blog

# JWT 密钥 (生产环境请使用强密码)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 管理员账户
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# 环境模式
NODE_ENV=development
